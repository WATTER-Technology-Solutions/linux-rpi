#!/bin/bash

target=$1
rev=5.4
kver="$(make kernelversion)-watter-$rev-rpi-2712"

function usage()
{
	echo "Pick one of: apollo" 1>&2
	exit 1
}

case "$1" in
apollo)
	export KDEB_PACKAGEEXT=apollo
	export KBUILD_IMAGE=arch/arm64/boot/Image.gz
	export ARCH=arm64
	;;
*)
	usage
esac

case "$1" in
*)
	image=bindeb-pkg
	export KDEB_CHANGELOG_DIST=stable
	export KDEB_SOURCENAME=linux-watter
	export KDEB_PKGVERSION=$kver
	export EMAIL="bcollins@watter.com"
	export NAME="Ben Collins"
	;;
esac

cpus=$(getconf _NPROCESSORS_ONLN)
nway=$(echo "($cpus * 15) / 10" | bc)
dir=${BUILD_DIR:-$(pwd)/build-${target}}

export HOSTCC=gcc
export CC=gcc
if [ "$(uname -m)" != "aarch64" ]; then
    export CROSS_COMPILE=aarch64-linux-gnu-
fi

export MAKEFLAGS="O=$dir -j$nway KERNELRELEASE=$kver ARCH=$ARCH"

if ! test -f "$dir/.config"; then
	test -d "$dir" || mkdir "$dir"
	cp "watter-configs/$target" "$dir/.config"
fi

make $image
